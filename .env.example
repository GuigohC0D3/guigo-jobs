# Guigo — Environment Configuration
# Copy this file to .env and fill in your values

# General
DEBUG=false
LOG_LEVEL=INFO

# Request settings
REQUEST_TIMEOUT=15
MAX_RETRIES=3

# Cache (set to false to always fetch fresh data)
CACHE_ENABLED=true
CACHE_TTL_MINUTES=30

# Optional API keys (providers work without keys but may have rate limits)
THEMUSE_API_KEY=
GREENHOUSE_API_KEY=

# Toggle providers (true/false)
ENABLE_REMOTEOK=true
ENABLE_REMOTIVE=true
ENABLE_ARBEITNOW=true
ENABLE_THEMUSE=true
# Brazil
ENABLE_GUPY=true
# Disabled by default
ENABLE_GREENHOUSE=false
ENABLE_LEVER=false

# Relevance scoring weights
SCORE_KEYWORD_MATCH=2.0
SCORE_TECH_MATCH=3.0
SCORE_JUNIOR_TITLE=1.5
SCORE_RECENT_POST=1.0
